{
  "name": "minute-frame",
  "version": "0.2.2",
  "description": "A meeting-first screen and audio recorder for macOS and Windows.",
  "main": "out/main/index.js",
  "author": "MinuteFrame contributors",
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "preview": "electron-vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "build": "npm run typecheck && npm run test && electron-vite build",
    "package": "npm run build && electron-builder",
    "build:mac-audio": "./scripts/build-macos-audio-helper.sh",
    "build:win-audio": "scripts\\build-windows-audio-helper.cmd",
    "package:mac": "./scripts/package-macos-adhoc.sh",
    "package:mac:adhoc": "./scripts/package-macos-adhoc.sh",
    "package:win": "npm run build:win-audio && npm run build && electron-builder --win"
  },
  "dependencies": {
    "lucide-react": "^0.525.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  },
  "devDependencies": {
    "@types/node": "^24.0.15",
    "@types/react": "^19.1.9",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^4.6.0",
    "electron": "43.1.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^4.0.0",
    "typescript": "^5.8.3",
    "vite": "^7.0.6",
    "vitest": "^3.2.4"
  },
  "build": {
    "appId": "com.minuteframe.app",
    "productName": "MinuteFrame",
    "artifactName": "MinuteFrame-${version}-${os}-${arch}.${ext}",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "mac": {
      "icon": "build/icon.png",
      "category": "public.app-category.productivity",
      "extraResources": [
        {
          "from": "build/native/macos/minuteframe-audio-capture",
          "to": "bin/minuteframe-audio-capture"
        }
      ],
      "target": [
        {
          "target": "dmg",
          "arch": ["universal"]
        },
        {
          "target": "zip",
          "arch": ["universal"]
        }
      ],
      "extendInfo": {
        "NSMicrophoneUsageDescription": "회의 참가자의 음성을 녹음하기 위해 마이크 접근이 필요합니다.",
        "NSAudioCaptureUsageDescription": "회의와 앱에서 재생되는 시스템 오디오를 녹음하기 위해 접근이 필요합니다.",
        "MinuteFramePermissionIdentity": "D69F06BB-91BE-4A87-9B3A-88156B85CA54"
      }
    },
    "win": {
      "icon": "build/icon.png",
      "extraResources": [
        {
          "from": "build/native/windows/${arch}/minuteframe-audio-capture.exe",
          "to": "bin/minuteframe-audio-capture.exe"
        }
      ],
      "target": [
        {
          "target": "nsis",
          "arch": ["x64", "arm64"]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
